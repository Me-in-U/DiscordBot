# Discord bot token
DISCORD_TOKEN=replace-with-discord-bot-token

# External API keys
OPENAI_KEY=replace-with-openai-api-key
GOOGLE_API_KEY=replace-with-google-api-key
RIOT_KEY=replace-with-riot-api-key
ECOS_API_KEY=replace-with-ecos-api-key

# Discord guild/channel IDs
SONPANNO_GUILD_ID=123456789012345678
SSAFY_GUILD_ID=123456789012345678

# MySQL connection
DB_HOST=localhost:3306
DB_DATABASE=discord_bot
DB_USERNAME=discord_bot
DB_PASSWORD=replace-with-db-password

# Embedded status/callback API
API_PORT=1557
CELEBRATION_UPDATE_API_KEY=replace-with-long-random-secret

# YouTube WebSub callback
YOUTUBE_WEBSUB_CALLBACK_URL=https://example.com/youtube/websub
YOUTUBE_WEBSUB_VERIFY_TOKEN=replace-with-long-random-token
